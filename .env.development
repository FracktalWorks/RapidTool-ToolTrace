# RapidTool-ToolTrace — Development
# Local dev: auth DISABLED (mock user) so no backend is needed.
VITE_API_URL=http://localhost:3000
VITE_API_TIMEOUT=10000
VITE_APP_URL=http://localhost:5173
VITE_PORTAL_URL=https://portal.appliedadditive.com

# Set false + run the backend to exercise real cookie auth locally.
VITE_DISABLE_AUTH=true

VITE_ENABLE_LOGGING=true
VITE_LOG_LEVEL=debug
NODE_ENV=development
