# RapidTool-ToolTrace — Environment template (copy to .env.development / .env.production)

# Backend API base (client.ts appends /api). Same backend as the rest of RapidTool.
VITE_API_URL=http://localhost:3000
VITE_API_TIMEOUT=10000

# This app's URL + the Portal (used for the post-login redirect / unauthenticated bounce).
VITE_APP_URL=http://localhost:5173
VITE_PORTAL_URL=https://portal.appliedadditive.com

# true = mock user, no backend needed (local dev). false = real cookie auth.
VITE_DISABLE_AUTH=true

VITE_ENABLE_LOGGING=true
VITE_LOG_LEVEL=debug
