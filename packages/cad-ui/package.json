{
  "name": "@rapidtool/cad-ui",
  "version": "0.1.0",
  "description": "Reusable React components for building internal applications - dashboards, CAD tools, and more",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./layout": {
      "import": "./src/layout/index.ts",
      "types": "./src/layout/index.ts"
    },
    "./sidebar": {
      "import": "./src/sidebar/index.ts",
      "types": "./src/sidebar/index.ts"
    },
    "./toolbar": {
      "import": "./src/toolbar/index.ts",
      "types": "./src/toolbar/index.ts"
    }
  },
  "dependencies": {
    "@rapidtool/cad-core": "*",
    "clsx": "^2.1.1",
    "immer": "^11.1.3",
    "tailwind-merge": "^2.5.5",
    "zustand": "^5.0.9"
  },
  "peerDependencies": {
    "@react-three/drei": "^9.0.0",
    "@react-three/fiber": "^8.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "three": ">=0.160.0"
  },
  "peerDependenciesMeta": {
    "@react-three/drei": {
      "optional": true
    },
    "@react-three/fiber": {
      "optional": true
    },
    "three": {
      "optional": true
    }
  },
  "devDependencies": {
    "@react-three/fiber": "^8.0.0",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@types/three": "^0.180.0",
    "typescript": "^5.6.3"
  },
  "keywords": [
    "ui",
    "dashboard",
    "layout",
    "sidebar",
    "react",
    "cad",
    "3d",
    "three.js",
    "viewport",
    "controls",
    "internal"
  ],
  "license": "MIT"
}
